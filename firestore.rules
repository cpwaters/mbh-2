rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Loads collection rules
    match /loads/{loadId} {
      // Any authenticated user can read loads (drivers browse all available loads)
      allow read: if isAuthenticated();

      // Only authenticated users can create loads, and must set their userId as createdBy
      allow create: if isAuthenticated()
                    && request.resource.data.createdBy == request.auth.uid;

      // The creator can update or delete their own loads
      allow update, delete: if isAuthenticated()
                            && resource.data.createdBy == request.auth.uid;

      // A driver may accept an open load: only status + acceptedBy/acceptedAt may change
      allow update: if isAuthenticated()
                    && resource.data.active_loads_status == 'open'
                    && request.resource.data.active_loads_status == 'accepted'
                    && request.resource.data.acceptedBy == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['active_loads_status', 'acceptedBy', 'acceptedAt']);

      // The accepting driver may mark their own in-progress load delivered
      allow update: if isAuthenticated()
                    && resource.data.acceptedBy == request.auth.uid
                    && resource.data.active_loads_status in ['accepted', 'collected', 'in_transit']
                    && request.resource.data.active_loads_status == 'delivered'
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['active_loads_status', 'deliveredAt']);
    }

    // Active jobs collection rules
    // Document ID must be the user's UID to enforce one active/accepted job per driver
    match /activeJobs/{userId} {
      // Only the driver can read their own active job
      allow read: if isOwner(userId);

      // Driver can create their active job only if document ID matches their UID
      allow create: if isOwner(userId)
                    && request.resource.data.userId == request.auth.uid;

      // Only the driver can update their own active job, and only to update progress/status —
      // not to silently swap which load it points to (that requires delete + create, i.e.
      // completing the current job first)
      allow update: if isOwner(userId)
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.loadId == resource.data.loadId;

      // Only the driver can delete their own active job (done as part of completing a job)
      allow delete: if isOwner(userId);
    }

    // Active loads collection rules
    match /activeLoads/{activeLoadId} {
      // Anyone authenticated can read active loads
      allow read: if isAuthenticated();

      // Active loads can be created by authenticated users with their userId
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;

      // Only the owner can update their active loads
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;

      // Only the owner can delete their active loads
      allow delete: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
    }

    // User profiles collection rules
    match /userProfiles/{userId} {
      // Only the profile owner can read their own profile
      allow read: if isOwner(userId);

      // Only the profile owner can create/update their own profile
      allow create, update: if isOwner(userId);

      // Only the profile owner can delete their own profile
      allow delete: if isOwner(userId);
    }

    // Vehicles collection rules
    match /vehicles/{vehicleId} {
      // Only the vehicle owner can read their own vehicles
      allow read: if isAuthenticated()
                  && resource.data.user_id == request.auth.uid;

      // Only authenticated users can create vehicles with their user_id
      allow create: if isAuthenticated()
                    && request.resource.data.user_id == request.auth.uid;

      // Only the vehicle owner can update/delete their vehicles
      allow update, delete: if isAuthenticated()
                            && resource.data.user_id == request.auth.uid;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}